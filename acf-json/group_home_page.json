{
    "key": "group_home_page",
    "title": "Home Page",
    "fields": [
        {
            "key": "tab_home_banner",
            "label": "Banner",
            "name": "",
            "type": "tab",
            "placement": "top"
        },
        {
            "key": "field_home_banners",
            "label": "Banner Slides",
            "name": "home_banners",
            "type": "repeater",
            "layout": "table",
            "button_label": "Thêm Slide",
            "sub_fields": [
                {
                    "key": "field_banner_type",
                    "label": "Type",
                    "name": "type",
                    "type": "select",
                    "choices": { "image": "Image", "video": "Video" },
                    "default_value": "image",
                    "ui": 1,
                    "return_format": "value"
                },
                {
                    "key": "field_banner_video",
                    "label": "Video (mp4)",
                    "name": "video",
                    "type": "file",
                    "return_format": "array",
                    "conditional_logic": [[{ "field": "field_banner_type", "operator": "==", "value": "video" }]]
                },
                {
                    "key": "field_banner_image_desktop",
                    "label": "Image Desktop",
                    "name": "image_desktop",
                    "type": "image",
                    "return_format": "array",
                    "conditional_logic": [[{ "field": "field_banner_type", "operator": "==", "value": "image" }]]
                },
                {
                    "key": "field_banner_image_mobile",
                    "label": "Image Mobile",
                    "name": "image_mobile",
                    "type": "image",
                    "return_format": "array",
                    "conditional_logic": [[{ "field": "field_banner_type", "operator": "==", "value": "image" }]]
                }
            ]
        },
        {
            "key": "field_home_banner_title",
            "label": "Banner Title (h2)",
            "name": "home_banner_title",
            "type": "text",
            "instructions": "Tiêu đề lớn giữa banner. VD: Fastener Sourcing Vietnam"
        },
        {
            "key": "field_home_banner_subtitle",
            "label": "Banner Subtitle",
            "name": "home_banner_subtitle",
            "type": "text",
            "instructions": "Dòng mô tả nhỏ dưới title"
        },
        {
            "key": "field_home_banner_bottom_items",
            "label": "Banner Bottom Items (swiper dưới)",
            "name": "home_banner_bottom_items",
            "type": "repeater",
            "layout": "table",
            "button_label": "Thêm Item",
            "sub_fields": [
                {
                    "key": "field_bbi_icon",
                    "label": "Icon (SVG/Image)",
                    "name": "icon",
                    "type": "image",
                    "return_format": "array"
                },
                {
                    "key": "field_bbi_title",
                    "label": "Title (h3)",
                    "name": "title",
                    "type": "text"
                },
                {
                    "key": "field_bbi_desc",
                    "label": "Sub Title",
                    "name": "desc",
                    "type": "text"
                },
                {
                    "key": "field_bbi_link",
                    "label": "Link",
                    "name": "link",
                    "type": "link",
                    "return_format": "array"
                }
            ]
        },
        {
            "key": "tab_home_about",
